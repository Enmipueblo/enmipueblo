---
import Layout from "../layouts/Layout.astro";
import DestacadosHomeIsland from "../components/DestacadosHomeIsland.tsx";

const CATEGORIES = [
  { label: "Fontaneros", emoji: "🛠️", href: "/buscar" },
  { label: "Electricistas", emoji: "⚡", href: "/buscar" },
  { label: "Modistas", emoji: "🧵", href: "/buscar" },
  { label: "Jardineros", emoji: "🪴", href: "/buscar" },
  { label: "Profesores", emoji: "💡", href: "/buscar" },
];
---

<Layout
  title="EnMiPueblo — Servicios en tu pueblo"
  description="Busca profesionales cerca, contacta en un clic y guarda favoritos."
>
  <section class="relative overflow-hidden rounded-[28px] bg-white/70 backdrop-blur ring-1 ring-black/5 shadow-sm">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-24 -left-24 h-72 w-72 rounded-full bg-[color:var(--sb-accent2)]/20 blur-3xl"></div>
      <div class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-[color:var(--sb-accent)]/20 blur-3xl"></div>
    </div>

    <div class="relative grid gap-8 lg:grid-cols-2 p-6 sm:p-10">
      <div class="max-w-xl">
        <p class="inline-flex items-center gap-2 rounded-full bg-black/5 px-3 py-1 text-xs font-extrabold tracking-wide text-[color:var(--sb-muted)]">
          EN TU ZONA
        </p>

        <h1 class="mt-4 text-4xl sm:text-5xl font-black tracking-tight text-[color:var(--sb-ink)]">
          Busca, ofrece o encuentra servicios <span class="text-[color:var(--sb-accent)]">en tu pueblo</span>
        </h1>

        <p class="mt-4 text-base sm:text-lg text-[color:var(--sb-muted)]">
          Encuentra profesionales cerca, contacta en un clic y guarda favoritos.
        </p>

        <form action="/buscar" class="mt-6 flex flex-col sm:flex-row gap-3">
          <div class="flex-1 rounded-2xl bg-white ring-1 ring-black/10 shadow-sm overflow-hidden">
            <input
              name="q"
              placeholder="¿Qué necesitas? (fontanero, modista, profesor...)"
              class="w-full px-4 py-3 text-base outline-none bg-transparent"
            />
          </div>

          <button
            type="submit"
            class="rounded-2xl px-6 py-3 font-extrabold text-white bg-[color:var(--sb-accent2)] hover:opacity-95 shadow-sm"
          >
            Buscar
          </button>
        </form>

        <div class="mt-4 flex flex-wrap gap-2">
          <a
            href="/buscar"
            class="rounded-full px-4 py-2 text-sm font-extrabold bg-white ring-1 ring-black/10 hover:bg-black/5"
          >
            Explorar servicios
          </a>
          <a
            href="/ofrecer"
            class="rounded-full px-4 py-2 text-sm font-extrabold bg-[color:var(--sb-soft)] text-[color:var(--sb-ink)] hover:bg-black/10"
          >
            Ofrecer un servicio
          </a>
        </div>
      </div>

      <div class="relative">
        <div class="relative overflow-hidden rounded-3xl ring-1 ring-black/10 bg-white shadow-sm">
          <img
            src="/brand/hero.jpg"
            onerror="this.onerror=null;this.src='/brand/hero.png';"
            alt="Profesionales en tu zona"
            class="h-[260px] sm:h-[320px] w-full object-cover"
            loading="eager"
          />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-r from-white/70 via-white/30 to-transparent"></div>
        </div>

        <div class="mt-3 text-sm text-[color:var(--sb-muted)]">
          <span class="font-bold text-[color:var(--sb-ink)]">Tip:</span> guarda tus favoritos y compara opciones rápido.
        </div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl sm:text-3xl font-black tracking-tight text-[color:var(--sb-ink)]">
          Lo más buscado
        </h2>
        <p class="mt-1 text-[color:var(--sb-muted)]">Accesos rápidos para empezar.</p>
      </div>

      <a href="/buscar" class="text-sm font-extrabold text-[color:var(--sb-accent)] hover:underline">
        Ver todo
      </a>
    </div>

    <div class="mt-5 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-3 sm:gap-4">
      {CATEGORIES.map((c) => (
        <a
          href={c.href}
          class="group rounded-3xl bg-white/80 ring-1 ring-black/10 shadow-sm hover:shadow-md transition-all p-4 sm:p-5"
        >
          <div class="flex items-center justify-center h-12 w-12 rounded-2xl bg-black/5 text-2xl">
            {c.emoji}
          </div>
          <div class="mt-3 font-black text-[color:var(--sb-ink)] group-hover:text-[color:var(--sb-accent)]">
            {c.label}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl sm:text-3xl font-black tracking-tight text-[color:var(--sb-ink)]">
      Destacados en tu zona
    </h2>
    <p class="mt-1 text-[color:var(--sb-muted)]">Mejor valorados y destacados.</p>

    <div class="mt-6">
      <DestacadosHomeIsland client:only="react" />
    </div>
  </section>
</Layout>
