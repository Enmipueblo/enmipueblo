---
import Layout from "../layouts/Layout.astro";
import DestacadosHomeIsland from "../components/DestacadosHomeIsland.tsx";
import GoogleAdIsland from "../components/GoogleAdIsland.tsx";

const LO_MAS = [
  { q: "Fontaneros", icon: "🛠️" },
  { q: "Electricistas", icon: "⚡" },
  { q: "Modistas", icon: "🧵" },
  { q: "Jardineros", icon: "🌿" },
  { q: "Profesores", icon: "💡" },
];

const CATS = [
  { q: "Reformas", icon: "🏠" },
  { q: "Cuidado", icon: "🧑‍🦳" },
  { q: "Clases", icon: "📚" },
  { q: "Mascotas", icon: "🐾" },
  { q: "Limpieza", icon: "🧼" },
  { q: "Tecnología", icon: "💻" },
];
---

<Layout title="EnMiPueblo">
  <section class="grid gap-6">
    <!-- HERO (sin texto encima de la imagen) -->
    <div class="rounded-3xl border overflow-hidden bg-white/70 backdrop-blur"
      style="border-color: var(--sb-border);">
      <div class="grid md:grid-cols-2">
        <div class="p-6 sm:p-8">
          <div class="text-xs font-extrabold tracking-widest uppercase"
            style="color: var(--sb-accent);">
            En tu zona
          </div>

          <h1 class="mt-3 text-3xl sm:text-4xl font-extrabold leading-tight"
            style="color: var(--sb-ink);">
            Encuentra servicios cerca de ti, rápido.
          </h1>

          <p class="mt-3 text-base sm:text-lg"
            style="color: var(--sb-ink2);">
            Busca profesionales, compara opciones y contacta en minutos.
          </p>

          <form action="/buscar" method="get" class="mt-5">
            <div class="flex flex-col sm:flex-row gap-3">
              <input
                name="texto"
                type="text"
                placeholder="¿Qué necesitas? (ej: electricista, clases, modista...)"
                class="w-full rounded-2xl border bg-white px-4 py-3 text-base"
                style="border-color: var(--sb-border);"
              />
              <button
                type="submit"
                class="rounded-2xl px-5 py-3 text-base font-extrabold text-white shadow-sm"
                style="background: var(--sb-accent);"
              >
                Buscar
              </button>
            </div>

            <div class="mt-4 flex flex-wrap gap-2">
              {CATS.map((c) => (
                <a
                  href={`/buscar?texto=${encodeURIComponent(c.q)}`}
                  class="inline-flex items-center gap-2 rounded-2xl border bg-white/80 px-3 py-2 text-sm font-semibold hover:bg-white"
                  style="border-color: var(--sb-border); color: var(--sb-ink);"
                >
                  <span aria-hidden="true">{c.icon}</span>
                  <span>{c.q}</span>
                </a>
              ))}
            </div>

            <div class="mt-5">
              <a
                href="/ofrecer"
                class="inline-flex items-center justify-center rounded-2xl border px-4 py-3 text-sm font-extrabold hover:bg-black/5"
                style="border-color: var(--sb-border); color: var(--sb-ink);"
              >
                Ofrecer un servicio
              </a>
            </div>
          </form>
        </div>

        <div class="relative min-h-[220px] md:min-h-full">
          <img
            src="/brand/hero.jpg"
            alt=""
            class="absolute inset-0 h-full w-full object-cover object-right"
            loading="eager"
          />
          <div class="absolute inset-0"
            style="background: linear-gradient(90deg, rgba(250,250,250,0.92) 0%, rgba(250,250,250,0.35) 45%, rgba(250,250,250,0.0) 80%);">
          </div>
        </div>
      </div>
    </div>

    <!-- LO MÁS BUSCADO -->
    <div class="rounded-3xl border bg-white/70 backdrop-blur p-6 sm:p-8"
      style="border-color: var(--sb-border);">
      <div class="flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl sm:text-3xl font-extrabold" style="color: var(--sb-ink);">
            Lo más buscado
          </h2>
          <p class="mt-1 text-sm sm:text-base" style="color: var(--sb-ink2);">
            Accesos rápidos para empezar.
          </p>
        </div>
        <a href="/buscar" class="text-sm font-extrabold hover:underline" style="color: var(--sb-accent2);">
          Ver todo
        </a>
      </div>

      <div class="mt-5 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4">
        {LO_MAS.map((i) => (
          <a
            href={`/buscar?texto=${encodeURIComponent(i.q)}`}
            class="group rounded-2xl border bg-white p-4 text-center shadow-sm hover:shadow"
            style="border-color: var(--sb-border);"
          >
            <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl border bg-white"
              style="border-color: var(--sb-border);">
              <span class="text-2xl" aria-hidden="true">{i.icon}</span>
            </div>
            <div class="mt-3 text-sm font-extrabold" style="color: var(--sb-ink);">
              {i.q}
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- PUBLICIDAD (placeholder) -->
    <GoogleAdIsland client:load />

    <!-- DESTACADOS -->
    <div class="rounded-3xl border bg-white/70 backdrop-blur p-6 sm:p-8"
      style="border-color: var(--sb-border);">
      <h2 class="text-2xl sm:text-3xl font-extrabold" style="color: var(--sb-ink);">
        Destacados en tu zona
      </h2>
      <p class="mt-1 text-sm sm:text-base" style="color: var(--sb-ink2);">
        Servicios seleccionados para ayudarte a encontrar rápido.
      </p>

      <div class="mt-6">
        <DestacadosHomeIsland client:load />
      </div>
    </div>
  </section>
</Layout>
