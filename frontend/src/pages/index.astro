---
import Layout from "../layouts/Layout.astro";
import DestacadosHomeIsland from "../components/DestacadosHomeIsland.tsx";

const CATEGORIES = [
  { label: "Fontaneros", emoji: "🛠️", href: "/buscar" },
  { label: "Electricistas", emoji: "⚡", href: "/buscar" },
  { label: "Modistas", emoji: "🧵", href: "/buscar" },
  { label: "Jardineros", emoji: "🪴", href: "/buscar" },
  { label: "Profesores", emoji: "💡", href: "/buscar" },
  { label: "Carpinteros", emoji: "🪚", href: "/buscar" },
];
---

<Layout
  title="EnMiPueblo — Servicios en tu pueblo"
  description="Busca profesionales cerca, contacta en un clic y guarda favoritos."
>
  <section class="relative min-h-[390px] overflow-hidden rounded-[28px] bg-white/70 backdrop-blur ring-1 ring-black/5 shadow-sm sm:min-h-[420px]">
    <div class="absolute inset-0 pointer-events-none">
      <div class="absolute -top-24 -left-24 h-72 w-72 rounded-full bg-[color:var(--sb-accent2)]/20 blur-3xl"></div>
      <div class="absolute -top-24 -right-24 h-72 w-72 rounded-full bg-[color:var(--sb-accent)]/20 blur-3xl"></div>

      <img
        src="/brand/web-portada-v2.png"
        alt=""
        class="absolute right-0 top-0 hidden h-full w-full object-cover object-right sm:block"
        loading="eager"
      />

      <div
        class="absolute inset-0 sm:hidden"
        style="background: linear-gradient(180deg, rgba(255,255,255,0.96) 0%, rgba(255,255,255,0.92) 100%);"
      ></div>

      <div class="absolute inset-0 hidden sm:block bg-gradient-to-r from-white/95 via-white/78 to-white/14"></div>
    </div>

    <div class="relative flex min-h-[390px] items-center p-5 sm:min-h-[420px] sm:px-8 sm:py-8">
      <div class="max-w-[600px]">
        <p class="inline-flex items-center gap-2 rounded-full bg-black/5 px-3 py-1 text-xs font-extrabold tracking-wide text-[color:var(--sb-muted)]">
          EN TU ZONA
        </p>

        <h1 class="mt-4 text-4xl font-black tracking-tight text-[color:var(--sb-ink)] sm:text-5xl">
          Busca, ofrece o encuentra servicios <span class="text-[color:var(--sb-accent)]">en tu pueblo</span>
        </h1>

        <p class="mt-4 max-w-[48ch] text-base text-[color:var(--sb-muted)] sm:text-lg">
          Encuentra profesionales cerca, contacta en un clic y guarda favoritos.
        </p>

        <form id="homeSearchForm" class="mt-6 flex max-w-[760px] flex-col gap-3 sm:flex-row">
          <div class="relative flex-1 overflow-hidden rounded-2xl bg-white ring-1 ring-black/10 shadow-sm">
            <input
              id="homeSearchInput"
              placeholder="Ej: bar en Graus, fontanero en Capella…"
              class="w-full bg-transparent px-4 py-3 text-base outline-none"
              autocomplete="off"
            />

            <div
              id="homeLocDropdown"
              class="absolute left-0 right-0 top-full z-50 mt-2 hidden overflow-hidden rounded-2xl bg-white shadow-lg ring-1 ring-black/10"
            ></div>

            <input type="hidden" name="texto" id="homeTexto" />
            <input type="hidden" name="pueblo" id="homePueblo" />
            <input type="hidden" name="provincia" id="homeProvincia" />
            <input type="hidden" name="comunidad" id="homeComunidad" />
          </div>

          <button
            type="submit"
            class="rounded-2xl bg-[color:var(--sb-accent2)] px-6 py-3 font-extrabold text-white shadow-sm hover:opacity-95"
          >
            Buscar
          </button>
        </form>

        <div class="mt-4 flex flex-wrap gap-2">
          <a
            href="/buscar"
            class="rounded-full bg-white px-4 py-2 text-sm font-extrabold ring-1 ring-black/10 hover:bg-black/5"
          >
            Explorar servicios
          </a>
          <a
            href="/ofrecer"
            class="rounded-full bg-[color:var(--sb-soft)] px-4 py-2 text-sm font-extrabold text-[color:var(--sb-ink)] hover:bg-black/10"
          >
            Ofrecer un servicio
          </a>
        </div>

        <div class="mt-4 text-sm text-[color:var(--sb-muted)]">
          <span class="font-bold text-[color:var(--sb-ink)]">Tip:</span> escribe “oficio en localidad”.
        </div>
      </div>
    </div>
  </section>

  <section class="mt-10">
    <div class="flex items-end justify-between gap-4">
      <div>
        <h2 class="text-2xl font-black tracking-tight text-[color:var(--sb-ink)] sm:text-3xl">
          Lo más buscado
        </h2>
        <p class="mt-1 text-[color:var(--sb-muted)]">Accesos rápidos para empezar.</p>
      </div>

      <a href="/buscar" class="text-sm font-extrabold text-[color:var(--sb-accent)] hover:underline">
        Ver todo
      </a>
    </div>

    <div class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-6">
      {CATEGORIES.map((c) => (
        <a
          href={c.href}
          class="group rounded-3xl bg-white/80 p-4 ring-1 ring-black/10 shadow-sm transition-all hover:shadow-md sm:p-5"
        >
          <div class="mx-auto flex h-14 w-14 items-center justify-center text-4xl sm:h-16 sm:w-16 sm:text-5xl">
            {c.emoji}
          </div>

          <div class="mt-3 text-center font-black text-[color:var(--sb-ink)] group-hover:text-[color:var(--sb-accent)]">
            {c.label}
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-2xl font-black tracking-tight text-[color:var(--sb-ink)] sm:text-3xl">
      Destacados en tu zona
    </h2>
    <p class="mt-1 text-[color:var(--sb-muted)]">Mejor valorados y destacados.</p>

    <div class="mt-6">
      <DestacadosHomeIsland client:only="react" />
    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById("homeSearchForm");
      const input = document.getElementById("homeSearchInput");
      const dd = document.getElementById("homeLocDropdown");

      const hTexto = document.getElementById("homeTexto");
      const hPueblo = document.getElementById("homePueblo");
      const hProv = document.getElementById("homeProvincia");
      const hCom = document.getElementById("homeComunidad");

      let timer = null;
      let lastQ = "";
      let selected = null;

      function esc(s) {
        return String(s || "").replace(/[&<>"']/g, (c) => ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[c]);
      }

      function hide() {
        dd.classList.add("hidden");
        dd.innerHTML = "";
      }

      function show(items, onPick) {
        if (!items || items.length === 0) return hide();
        dd.innerHTML = items
          .map((it, idx) => {
            return (
              `<button type="button" data-idx="${idx}" class="w-full text-left px-4 py-3 hover:bg-black/5 text-sm">` +
              `<div class="font-extrabold" style="color: var(--sb-ink)">${esc(it.nombre)}</div>` +
              `<div class="text-xs" style="color: var(--sb-ink2)">${esc([it.provincia, it.ccaa].filter(Boolean).join(" · "))}</div>` +
              `</button>`
            );
          })
          .join("");
        dd.classList.remove("hidden");

        dd.querySelectorAll("button[data-idx]").forEach((btn) => {
          btn.addEventListener("click", () => {
            const idx = Number(btn.getAttribute("data-idx"));
            const it = items[idx];
            onPick(it);
            hide();
          });
        });
      }

      function parseQuery(raw) {
        const s = String(raw || "").trim();
        const lower = s.toLowerCase();
        const token = " en ";
        const pos = lower.lastIndexOf(token);
        if (pos >= 0) {
          const left = s.slice(0, pos).trim();
          const right = s.slice(pos + token.length).trim();
          return { texto: left, loc: right };
        }
        return { texto: s, loc: "" };
      }

      async function fetchLocalidades(q) {
        const res = await fetch("/api/localidades?q=" + encodeURIComponent(q));
        const json = await res.json().catch(() => ({}));
        return Array.isArray(json?.data) ? json.data : [];
      }

      input.addEventListener("input", () => {
        selected = null;
        hPueblo.value = "";
        hProv.value = "";
        hCom.value = "";

        const { texto, loc } = parseQuery(input.value);
        hTexto.value = texto || input.value.trim();

        const qLoc = (loc || "").trim();
        if (timer) clearTimeout(timer);

        if (qLoc.length < 2) {
          hide();
          return;
        }

        timer = setTimeout(async () => {
          try {
            if (qLoc === lastQ) return;
            lastQ = qLoc;
            const items = await fetchLocalidades(qLoc);

            show(items.slice(0, 10), (it) => {
              selected = it;
              const left = (texto || "").trim();
              const label = it?.nombre || qLoc;
              input.value = left ? left + " en " + label : label;

              hTexto.value = left || "";
              hPueblo.value = it?.nombre || "";
              hProv.value = it?.provincia || "";
              hCom.value = it?.ccaa || "";
            });
          } catch {
            hide();
          }
        }, 250);
      });

      document.addEventListener("click", (e) => {
        if (!dd.contains(e.target) && e.target !== input) hide();
      });

      form.addEventListener("submit", (e) => {
        e.preventDefault();

        const { texto, loc } = parseQuery(input.value);
        const qTexto = (texto || "").trim();
        const qLoc = (loc || "").trim();
        const pueblo = hPueblo.value || qLoc || "";

        const sp = new URLSearchParams();
        if (qTexto) sp.set("texto", qTexto);
        if (pueblo) sp.set("pueblo", pueblo);
        if (hProv.value) sp.set("provincia", hProv.value);
        if (hCom.value) sp.set("comunidad", hCom.value);
        sp.set("page", "1");

        window.location.href = "/buscar?" + sp.toString();
      });
    })();
  </script>
</Layout>