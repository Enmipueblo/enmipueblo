---
import Layout from "../layouts/Layout.astro";
import ContactFormIsland from "../components/ContactFormIsland.tsx";
---

<Layout title="Contacto — EnMiPueblo" description="Contáctanos para soporte, sugerencias o incidencias.">
  <section class="py-8 sm:py-10">
    <div class="rounded-3xl border shadow-[var(--sb-shadow)] overflow-hidden"
      style="border-color:var(--sb-border); background:var(--sb-card2)">
      <div class="p-7 sm:p-10">
        <div class="text-xs font-extrabold tracking-widest uppercase" style="color:var(--sb-muted)">Soporte</div>
        <h1 class="mt-2 text-3xl sm:text-4xl font-extrabold" style="color:var(--sb-ink)">Contacto</h1>
        <p class="mt-2 text-base sm:text-lg" style="color:var(--sb-ink2)">
          Si algo no funciona, tenés una sugerencia o querés ayuda, escribinos acá.
        </p>
      </div>
    </div>

    <div class="mt-7 sm:mt-8">
      <ContactFormIsland client:load />
    </div>
  </section>
</Layout>
