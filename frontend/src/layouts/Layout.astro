---
import Header from "../components/Header.astro";
import Footer from "../components/footer.astro";
import CookieConsentIsland from "../components/CookieConsentIsland.tsx";

const {
  title = "EnMiPueblo",
  description = "Encuentra y ofrece servicios en tu zona.",
  noIndex = false,
} = Astro.props;

const THEME_VARS = `
:root{
  --sb-bg:#f4f4f5;          /* zinc-100 */
  --sb-card:rgba(255,255,255,.82);
  --sb-card2:rgba(255,255,255,.94);
  --sb-ink:#0b0f14;         /* casi negro */
  --sb-ink2:#334155;        /* slate-700 */
  --sb-muted:#64748b;       /* slate-500 */
  --sb-border:rgba(15,23,42,.14);
  --sb-accent:#16a34a;      /* green-600 */
  --sb-accent2:#15803d;     /* green-700 */
}
`;

const BG_STYLE = `
background:
  radial-gradient(1200px 520px at 10% -10%, rgba(22,163,74,0.18) 0%, rgba(22,163,74,0) 60%),
  radial-gradient(1000px 520px at 95% 0%, rgba(37,99,235,0.12) 0%, rgba(37,99,235,0) 55%),
  linear-gradient(180deg, #fafafa 0%, #f4f4f5 35%, #fafafa 100%);
`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {noIndex ? <meta name="robots" content="noindex,nofollow" /> : null}
    <title>{title}</title>

    <style is:inline set:html={THEME_VARS}></style>
  </head>

  <body style={BG_STYLE} class="min-h-screen text-[16px] sm:text-[17px] antialiased text-slate-900">
    <div class="min-h-screen">
      <Header />

      <main class="mx-auto max-w-6xl px-4 py-6 sm:py-8">
        <slot />
      </main>

      <Footer />
      <CookieConsentIsland client:load />
    </div>
  </body>
</html>
