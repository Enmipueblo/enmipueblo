---
import Header from "../components/Header.astro";
import Footer from "../components/footer.astro";
import "../styles/global.css";

const { title = "EnMiPueblo", description = "Servicios y profesionales cerca de ti." } = Astro.props;

const THEME_VARS = `
  :root{
    --sb-bg: #EDE7DF;
    --sb-card: rgba(255,255,255,0.72);
    --sb-card2: rgba(255,255,255,0.82);
    --sb-border: rgba(15,23,42,0.14);

    --sb-ink: #0f172a;
    --sb-ink2: #334155;
    --sb-muted: rgba(15,23,42,0.62);

    --sb-accent: #C45B34;
    --sb-orange: var(--sb-accent);
    --sb-on-accent: #ffffff;

    --sb-shadow: 0 18px 55px -44px rgba(0,0,0,0.45);
  }
`;

const BG_STYLE = `
  background:
    radial-gradient(900px 460px at 10% -10%, rgba(196,91,52,0.18) 0%, rgba(196,91,52,0) 62%),
    radial-gradient(760px 420px at 92% -6%, rgba(15,23,42,0.12) 0%, rgba(15,23,42,0) 60%),
    linear-gradient(180deg, rgba(255,255,255,0.70) 0%, rgba(255,255,255,0.00) 55%);
`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/brand/favicon.png" />
    <style set:html={THEME_VARS} />
  </head>

  <body class="min-h-screen bg-[var(--sb-bg)] text-[var(--sb-ink)] antialiased text-[15px] sm:text-[16px] leading-relaxed" style={BG_STYLE}>
    <Header />
    <main class="mx-auto max-w-6xl px-4 pt-4 pb-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>
