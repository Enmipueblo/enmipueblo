---
import Header from "../components/Header.astro";
import Footer from "../components/footer.astro";
import CookieConsentIsland from "../components/CookieConsentIsland.tsx";
import "../styles/global.css";

const {
  title = "EnMiPueblo",
  description = "Busca, ofrece o encuentra servicios en tu pueblo.",
  noindex = false,
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="icon" type="image/png" href="/brand/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="theme-color" content="#d65d0e" />
  </head>

  <body>

    <Header />

    <!-- ESTE PADDING ES LA SOLUCIÓN -->
    <main class="pt-[90px] w-full min-h-screen">

      <div class="sb-container py-6 sm:py-8">
        <slot />
      </div>

    </main>

    <Footer />

    <CookieConsentIsland client:load />

  </body>
</html>