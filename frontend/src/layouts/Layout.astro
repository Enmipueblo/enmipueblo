---
/* frontend/src/layouts/Layout.astro */
import Header from "../components/Header.astro";
import Footer from "../components/footer.astro";
import CookieConsentIsland from "../components/CookieConsentIsland.tsx";
import "../styles/global.css";

const {
  title = "EnMiPueblo",
  description = "Busca, ofrece o encuentra servicios en tu pueblo.",
  noindex = false,
} = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Favicons -->
    <link rel="icon" type="image/png" href="/brand/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta name="theme-color" content="#d65d0e" />
  </head>

  <body>
    <div class="min-h-screen flex flex-col">
      <Header />

      <main class="flex-1 w-full">
        <div class="sb-container py-6 sm:py-8">
          <slot />
        </div>
      </main>

      <Footer />
      <CookieConsentIsland client:load />
    </div>

    <!-- ✅ Calcula la altura REAL del header y reserva espacio -->
    <script is:inline>
      (function () {
        function setHeaderH() {
          var el = document.getElementById("site-header");
          if (!el) return;
          var h = Math.ceil(el.getBoundingClientRect().height || 0);
          if (h > 0) document.documentElement.style.setProperty("--sb-header-h", h + "px");
        }

        var t = null;
        function onResize() {
          if (t) clearTimeout(t);
          t = setTimeout(setHeaderH, 80);
        }

        window.addEventListener("load", setHeaderH);
        window.addEventListener("resize", onResize);
        // Por si carga primero la fuente y cambia altura:
        setTimeout(setHeaderH, 300);
        setTimeout(setHeaderH, 1200);
      })();
    </script>
  </body>
</html>