---
import AuthIsland from "./AuthIsland.tsx";

const NAV = [
  { href: "/", label: "Inicio" },
  { href: "/buscar", label: "Buscar" },
  { href: "/ofrecer", label: "Ofrecer" },
  { href: "/contacto", label: "Contacto" },
  { href: "/mi-panel", label: "Mi panel" },
  { href: "/admin/panel", label: "Admin" },
];
---

<header class="sticky top-0 z-50">
  <div class="border-b backdrop-blur bg-white/80" style="border-color: var(--sb-border);">
    <div class="mx-auto max-w-6xl px-4 py-3 flex items-center justify-between gap-3">
      <div class="flex items-center gap-3">
        <a href="/" class="flex items-center gap-2 rounded-xl px-2 py-1 hover:bg-black/5">
          <img src="/brand/logo-web.png" alt="EnMiPueblo" class="h-7 w-auto" loading="eager" />
          <span class="hidden sm:inline text-sm font-extrabold tracking-tight" style="color:var(--sb-ink);">
            EnMiPueblo
          </span>
        </a>

        <nav class="hidden lg:flex items-center gap-1">
          {NAV.map((item) => (
            <a
              href={item.href}
              class="px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5"
              style="color: var(--sb-ink);"
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <div class="flex items-center gap-2">
        <div class="hidden md:block">
          <AuthIsland client:load />
        </div>

        <button
          id="navBtn"
          type="button"
          class="lg:hidden inline-flex items-center justify-center rounded-xl border px-3 py-2 text-sm font-semibold bg-white hover:bg-black/5"
          style="border-color: var(--sb-border); color: var(--sb-ink);"
          aria-controls="mobileNav"
          aria-expanded="false"
        >
          Menú
        </button>
      </div>
    </div>

    <div id="mobileNav" class="lg:hidden hidden">
      <div class="mx-auto max-w-6xl px-4 pb-4">
        <div class="rounded-2xl border bg-white" style="border-color: var(--sb-border);">
          <div class="p-3 grid gap-1">
            {NAV.map((item) => (
              <a
                href={item.href}
                class="px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5"
                style="color: var(--sb-ink);"
              >
                {item.label}
              </a>
            ))}

            <div class="mt-2 border-t pt-3 md:hidden" style="border-color: var(--sb-border);">
              <AuthIsland client:load />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const btn = document.getElementById("navBtn");
      const nav = document.getElementById("mobileNav");
      if (!btn || !nav) return;

      const setOpen = (open) => {
        nav.classList.toggle("hidden", !open);
        btn.setAttribute("aria-expanded", open ? "true" : "false");
      };

      btn.addEventListener("click", () => {
        const open = btn.getAttribute("aria-expanded") !== "true";
        setOpen(open);
      });

      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape") setOpen(false);
      });
    })();
  </script>
</header>
