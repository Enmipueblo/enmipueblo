---
import AuthIsland from "./AuthIsland.tsx";
---

<header
  class="fixed top-0 left-0 right-0 z-[1000] w-full border-b"
  style="background: rgba(255,255,255,0.92); border-color: var(--sb-border); backdrop-filter: blur(12px);"
>
  <div class="sb-container flex items-center justify-between py-4 gap-3">

    <a href="/" class="flex items-center gap-3 min-w-[140px]">
      <span
        class="inline-block h-9 w-40 bg-[url('/brand/logo-web.png')] bg-left bg-contain bg-no-repeat"
        aria-label="EnMiPueblo"
      ></span>
      <span class="sr-only">EnMiPueblo</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-[15px] font-extrabold" style="color: var(--sb-ink);">
      <a href="/buscar" class="hover:opacity-80">Buscar</a>
      <a href="/ofrecer" class="hover:opacity-80">Ofrecer</a>
      <a href="/contacto" class="hover:opacity-80">Contacto</a>
      <a href="/mi-panel" class="hover:opacity-80">Mi panel</a>
    </nav>

    <div class="flex items-center gap-2">
      <details class="md:hidden relative">
        <summary
          class="list-none cursor-pointer inline-flex items-center justify-center rounded-2xl px-3 py-2 text-sm font-extrabold border"
          style="background: rgba(255,255,255,0.65); border-color: var(--sb-border); color: var(--sb-ink);"
        >
          ☰
        </summary>

        <div
          class="absolute right-0 mt-2 w-56 rounded-2xl border shadow-lg p-2"
          style="background: rgba(255,255,255,0.92); border-color: var(--sb-border);"
        >
          <a href="/buscar" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Buscar</a>
          <a href="/ofrecer" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Ofrecer</a>
          <a href="/contacto" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Contacto</a>
          <a href="/mi-panel" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Mi panel</a>
        </div>
      </details>

      <AuthIsland client:only="react" />
    </div>

  </div>
</header>