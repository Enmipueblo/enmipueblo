---
import AuthIsland from "./AuthIsland";

const nav = [
  { href: "/buscar", label: "Buscar" },
  { href: "/ofrecer", label: "Ofrecer" },
  { href: "/contacto", label: "Contacto" },
];

const brand = {
  logoSrc: "/brand/logo-web.png",
  nameText: "EnMiPueblo",
};
---

<header class="w-full">
  <div class="w-full" style="background: linear-gradient(180deg, rgba(47,143,134,0.10), rgba(47,143,134,0.0)); border-bottom: 1px solid rgba(31,41,55,0.06);">
    <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2">
        <img src={brand.logoSrc} alt="EnMiPueblo" class="h-8 w-auto" loading="eager" />
        <span class="font-extrabold tracking-tight text-lg sm:text-xl" style="color: var(--sb-ink);">{brand.nameText}<span style="color: var(--sb-accent);">.</span></span>
      </a>

      <nav class="hidden md:flex items-center gap-7">
        {nav.map((it) => (
          <a href={it.href} class="font-semibold text-base" style="color: var(--sb-ink);">
            {it.label}
          </a>
        ))}
      </nav>

      <div class="flex items-center gap-3">
        <AuthIsland client:load />
      </div>
    </div>
  </div>
</header>
