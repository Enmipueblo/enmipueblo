---
/* frontend/src/components/Header.astro */
import AuthIsland from "./AuthIsland.tsx";
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 w-full border-b"
  style="
    background: rgba(255, 255, 255, 0.96);
    border-color: var(--sb-border);
    box-shadow: 0 12px 30px -22px rgba(0,0,0,0.35);
    backdrop-filter: saturate(180%) blur(12px);
  "
>
  <div class="sb-container flex items-center justify-between py-4 gap-3">
    <a href="/" class="flex items-center gap-3 min-w-[140px]">
      <span
        class="inline-block h-9 w-40 bg-[url('/brand/logo-web.png')] bg-left bg-contain bg-no-repeat"
        aria-label="EnMiPueblo"
      ></span>
      <span class="sr-only">EnMiPueblo</span>
    </a>

    <nav class="hidden md:flex items-center gap-6 text-[15px] font-extrabold" style="color: var(--sb-ink);">
      <a href="/buscar" class="hover:opacity-80">Buscar</a>
      <a href="/ofrecer" class="hover:opacity-80">Ofrecer</a>
      <a href="/contacto" class="hover:opacity-80">Contacto</a>
      <a href="/mi-panel" class="hover:opacity-80">Mi panel</a>

      <details class="relative">
        <summary class="cursor-pointer list-none hover:opacity-80 inline-flex items-center gap-1">
          Legal <span class="text-xs opacity-70">▾</span>
        </summary>
        <div
          class="absolute right-0 mt-2 w-56 rounded-2xl border shadow-lg p-2"
          style="background: #fff; border-color: var(--sb-border);"
        >
          <a href="/aviso-legal" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Aviso legal</a>
          <a href="/politica-privacidad" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Privacidad</a>
          <a href="/politica-cookies" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Cookies</a>
          <a href="/terminos" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Términos</a>
        </div>
      </details>
    </nav>

    <div class="flex items-center justify-end gap-2">
      <details class="md:hidden relative">
        <summary
          class="list-none cursor-pointer inline-flex items-center justify-center rounded-2xl px-3 py-2 text-sm font-extrabold border"
          style="background: #fff; border-color: var(--sb-border); color: var(--sb-ink);"
          aria-label="Abrir menú"
        >
          ☰
        </summary>
        <div
          class="absolute right-0 mt-2 w-56 rounded-2xl border shadow-lg p-2"
          style="background: #fff; border-color: var(--sb-border);"
        >
          <a href="/buscar" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Buscar</a>
          <a href="/ofrecer" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Ofrecer</a>
          <a href="/contacto" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Contacto</a>
          <a href="/mi-panel" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Mi panel</a>
          <div class="my-2 h-px" style="background: rgba(15,23,42,0.10)"></div>
          <a href="/aviso-legal" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Aviso legal</a>
          <a href="/politica-privacidad" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Privacidad</a>
          <a href="/politica-cookies" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Cookies</a>
          <a href="/terminos" class="block rounded-xl px-3 py-2 text-sm font-bold hover:bg-black/5">Términos</a>
        </div>
      </details>

      <AuthIsland client:only="react" />
    </div>
  </div>
</header>

<script is:inline>
  (() => {
    const root = document.documentElement;
    const header = document.getElementById("site-header");
    if (!root || !header) return;

    let rafId = 0;

    const syncHeaderHeight = () => {
      rafId = 0;
      const nextHeight = Math.max(76, Math.ceil(header.getBoundingClientRect().height || header.offsetHeight || 76));
      root.style.setProperty("--sb-header-h", nextHeight + "px");
    };

    const scheduleSync = () => {
      if (rafId) return;
      rafId = window.requestAnimationFrame(syncHeaderHeight);
    };

    scheduleSync();
    window.addEventListener("load", scheduleSync, { passive: true });
    window.addEventListener("resize", scheduleSync, { passive: true });

    if (typeof ResizeObserver !== "undefined") {
      const ro = new ResizeObserver(scheduleSync);
      ro.observe(header);
    }
  })();
</script>