---
import AuthIsland from "./AuthIsland.tsx";

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  pathname === href || (href !== "/" && pathname.startsWith(href + "/"));

const linkClass = (href: string) =>
  `px-3 py-2 rounded-full text-sm font-semibold transition-colors ${
    isActive(href)
      ? "bg-black/5 text-[color:var(--sb-ink)]"
      : "text-[color:var(--sb-muted)] hover:text-[color:var(--sb-ink)] hover:bg-black/5"
  }`;
---

<header class="sticky top-0 z-40 bg-[color:var(--sb-card)]/90 backdrop-blur-md border-b border-black/5">
  <div class="px-4 sm:px-8 py-3 flex items-center justify-between gap-3">
    <a href="/" class="flex items-center gap-2 min-w-0">
      <img
        src="/brand/logo-web.png"
        onerror="this.onerror=null;this.src='/brand/logo%20web.png';"
        alt="EnMiPueblo"
        class="h-9 w-auto shrink-0"
        loading="eager"
      />
      <span class="hidden sm:inline text-xl font-black tracking-tight truncate">
        <span class="text-[color:var(--sb-ink)]">en</span><span class="text-[color:var(--sb-accent)]">Mi</span><span class="text-[color:var(--sb-ink)]">Pueblo</span><span class="ml-1 text-xs font-semibold text-[color:var(--sb-muted)]">.com</span>
      </span>
    </a>

    <nav class="hidden md:flex items-center gap-1">
      <a href="/buscar" class={linkClass("/buscar")}>Buscar</a>
      <a href="/ofrecer" class={linkClass("/ofrecer")}>Ofrecer</a>
      <a href="/contacto" class={linkClass("/contacto")}>Contacto</a>
      <a href="/mi-panel" class={linkClass("/mi-panel")}>Mi panel</a>

      <details class="relative">
        <summary class={`px-3 py-2 rounded-full text-sm font-semibold transition-colors ${
          pathname.startsWith("/aviso-legal") ||
          pathname.startsWith("/politica-privacidad") ||
          pathname.startsWith("/politica-cookies") ||
          pathname.startsWith("/terminos")
            ? "bg-black/5 text-[color:var(--sb-ink)]"
            : "text-[color:var(--sb-muted)] hover:text-[color:var(--sb-ink)] hover:bg-black/5"
        }`}>Legal ▾</summary>

        <div class="absolute right-0 mt-2 w-56 rounded-2xl bg-white shadow-xl ring-1 ring-black/10 p-2">
          <a href="/aviso-legal" class="block px-3 py-2 rounded-xl text-sm font-semibold text-[color:var(--sb-ink)] hover:bg-black/5">Aviso legal</a>
          <a href="/politica-privacidad" class="block px-3 py-2 rounded-xl text-sm font-semibold text-[color:var(--sb-ink)] hover:bg-black/5">Privacidad</a>
          <a href="/politica-cookies" class="block px-3 py-2 rounded-xl text-sm font-semibold text-[color:var(--sb-ink)] hover:bg-black/5">Cookies</a>
          <a href="/terminos" class="block px-3 py-2 rounded-xl text-sm font-semibold text-[color:var(--sb-ink)] hover:bg-black/5">Términos</a>
        </div>
      </details>
    </nav>

    <div class="flex items-center gap-2">
      <AuthIsland client:only="react" />

      <details class="relative md:hidden">
        <summary class="px-3 py-2 rounded-2xl text-sm font-bold bg-black/5 text-[color:var(--sb-ink)]">
          Menú
        </summary>
        <div class="absolute right-0 mt-2 w-64 rounded-2xl bg-white shadow-xl ring-1 ring-black/10 p-2">
          <a href="/buscar" class="block px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5">Buscar</a>
          <a href="/ofrecer" class="block px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5">Ofrecer</a>
          <a href="/contacto" class="block px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5">Contacto</a>
          <a href="/mi-panel" class="block px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5">Mi panel</a>
          <div class="my-2 h-px bg-black/10"></div>
          <a href="/aviso-legal" class="block px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5">Aviso legal</a>
          <a href="/politica-privacidad" class="block px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5">Privacidad</a>
          <a href="/politica-cookies" class="block px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5">Cookies</a>
          <a href="/terminos" class="block px-3 py-2 rounded-xl text-sm font-semibold hover:bg-black/5">Términos</a>
        </div>
      </details>
    </div>
  </div>
</header>
