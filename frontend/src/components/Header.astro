---
import AuthIsland from "./AuthIsland.tsx";
---

<header class="w-full border-b border-slate-200/70 bg-white/70 backdrop-blur">
  <div class="mx-auto flex w-full max-w-[1400px] items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-3">
      <img src="/brand/logo-web.png" alt="EnMiPueblo" class="h-8 w-auto" loading="eager" />
      <span class="sr-only">EnMiPueblo</span>
    </a>

    <nav class="hidden items-center gap-6 text-sm font-semibold text-slate-700 md:flex">
      <a class="hover:text-slate-900" href="/buscar">Buscar</a>
      <a class="hover:text-slate-900" href="/ofrecer">Ofrecer</a>
      <a class="hover:text-slate-900" href="/contacto">Contacto</a>
      <a class="hover:text-slate-900" href="/usuario/panel">Mi panel</a>

      <details class="relative">
        <summary class="cursor-pointer list-none hover:text-slate-900">Legal ▾</summary>
        <div class="absolute right-0 mt-2 w-56 rounded-2xl border border-slate-200 bg-white p-2 shadow-xl">
          <a class="block rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" href="/aviso-legal">Aviso legal</a>
          <a class="block rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" href="/politica-privacidad">Privacidad</a>
          <a class="block rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" href="/politica-cookies">Cookies</a>
          <a class="block rounded-xl px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50" href="/terminos">Términos</a>
        </div>
      </details>
    </nav>

    <div class="flex items-center gap-2">
      <AuthIsland client:load />
    </div>
  </div>
</header>
